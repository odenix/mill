/// Core schema for declarative Scala modules.
///
/// This corresponds to Mill's `mill.scalalib.ScalaModule`.
open module ScalaModule

extends "Module.pkl"

/// Scala version used to compile this module.
scalaVersion: String?

/// Command-line options passed to the Scala compiler.
scalacOptions: Listing<String>?

/// Scala compiler plugins resolved from Maven / Ivy repositories.
scalacPluginMvnDeps: Listing<String>?

/// Scala.js version for modules that target Scala.js.
scalaJSVersion: String?

/// Scala.js module kind, for example `NoModule`, `CommonJSModule`, or
/// `ESModule`.
moduleKind: "NoModule" | "CommonJSModule" | "ESModule" | String?

/// Scala Native version for modules that target Scala Native.
scalaNativeVersion: String?
