/// Core schema for declarative Kotlin modules.
///
/// This corresponds to Mill's `mill.kotlinlib.KotlinModule`.
open module KotlinModule

extends "JavaModule.pkl"

typealias KotlinLanguageOrApiVersion = String(matches(Regex(#"^\d+\.\d+$"#)))

/// Kotlin version used for the compiler, API level, and language level.
kotlinVersion: String?

/// Kotlin compiler language version.
///
/// By default, Mill derives this from [kotlinVersion].
kotlinLanguageVersion: KotlinLanguageOrApiVersion?

/// Kotlin compiler API version.
///
/// By default, Mill derives this from [kotlinLanguageVersion].
kotlinApiVersion: KotlinLanguageOrApiVersion?

/// Additional options passed to the Kotlin compiler.
kotlincOptions: Listing<String>?

/// Kotlin compiler plugins resolved from Maven / Ivy repositories.
kotlincPluginMvnDeps: Listing<String>?
