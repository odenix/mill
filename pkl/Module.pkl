/// Base schema for declarative Mill modules.
///
/// Specialized schemas such as [JavaModule], [ScalaModule], and [KotlinModule]
/// extend this module and add language-specific settings.
open module Module

import "Module.pkl"

typealias NonSlashString = String(!contains("/"))

/// A Mill dependency coordinate.
///
/// These are usually Maven / Ivy-style coordinates such as `org:name:version`
/// for Java artifacts or `org::name:version` for Scala cross-published
/// artifacts. The accepted syntax is broader than plain Maven GAV because Mill
/// supports cross versions and additional dependency metadata.
typealias DepCoordinate = String

/// License metadata published in the generated `pom.xml`.
class License {
  /// Human-readable license name.
  name: String

  /// Canonical license URL.
  url: Uri
}

/// Version-control metadata published in the generated `pom.xml`.
class VersionControl {
  /// Browser URL for the source repository.
  url: Uri

  /// Read-only SCM connection string.
  connection: String

  /// Read-write SCM connection string for developers.
  developerConnection: String

  /// Source-control tag or revision associated with this publication.
  tag: String?
}

/// Developer metadata published in the generated `pom.xml`.
class Developer {
  /// Developer identifier.
  id: String

  /// Developer display name.
  name: String

  /// Developer homepage URL.
  url: Uri

  /// Optional organization name.
  organization: String?

  /// Optional organization homepage URL.
  organizationUrl: Uri?
}

/// Configuration for the `pom.xml` metadata file published with this module.
class PomSettings {
  /// Project description published in the POM.
  description: String

  /// Maven organization / group identifier used for publication.
  organization: NonSlashString

  /// Project homepage URL.
  url: Uri

  /// Declared project licenses.
  licenses: Listing<License>

  /// Version-control metadata for the project.
  versionControl: VersionControl

  /// Declared project developers.
  developers: Listing<Developer>
}

/// Configuration for the meta-build in `mill-build`.
class MillBuild {
  /// Additional BSP script ignore patterns for `mill-build`.
  bspScriptIgnore: Listing<String>?

  /// Extra repositories used to resolve dependencies for the meta-build.
  repositories: Listing<String>?

  /// Additional Maven / Ivy dependencies for the meta-build.
  mvnDeps: Listing<DepCoordinate>?

  /// Compile-only Maven / Ivy dependencies for the meta-build.
  compileMvnDeps: Listing<DepCoordinate>?

  /// Runtime-only Maven / Ivy dependencies for the meta-build.
  runMvnDeps: Listing<DepCoordinate>?

  /// Bill of Material (BOM) dependencies for the meta-build.
  bomMvnDeps: Listing<DepCoordinate>?

  /// Dependency-management entries for the meta-build.
  depManagement: Listing<DepCoordinate>?
}

/// Mill version used for this build.
millVersion: String?

/// JVM version Mill should use by default for Java, Scala, and Kotlin modules.
millJvmVersion: String?

/// Version of the JVM index used to resolve [millJvmVersion].
millJvmIndexVersion: String?

/// JVM options passed to the Mill process itself.
millJvmOpts: Listing<String>?

/// Additional Mill command-line options.
millOpts: Listing<String>?

/// Whether nested `build.mill` files are allowed below the workspace root.
millAllowNestedBuildMill: Boolean?

/// Global repositories used for resolving Mill's own dependencies and as
/// default repositories for dependency resolution.
millRepositories: Listing<String>?

/// Configuration for the `mill-build` meta-build.
millBuild: MillBuild?

/// Direct module dependencies of this module.
moduleDeps: Listing<String>?

/// Compile-only direct module dependencies.
compileModuleDeps: Listing<String>?

/// Runtime-only direct module dependencies.
runModuleDeps: Listing<String>?

/// Bill of Material (BOM) module dependencies.
bomModuleDeps: Listing<String>?

/// Additional Maven / Ivy dependencies for this module.
mvnDeps: Listing<DepCoordinate>?

/// Compile-only Maven / Ivy dependencies.
compileMvnDeps: Listing<DepCoordinate>?

/// Runtime-only Maven / Ivy dependencies.
runMvnDeps: Listing<DepCoordinate>?

/// Bill of Material (BOM) dependencies for this module.
bomMvnDeps: Listing<DepCoordinate>?

/// Dependency-management entries that can override versions and exclusions of
/// transitive dependencies.
depManagement: Listing<DepCoordinate>?

/// Source-root folders used by the module's default `sources` task.
sourcesFolders: Listing<String>?

/// Sources to compile for this module.
sources: Listing<String>?

/// Resource directories included on the runtime classpath.
resources: Listing<String>?

/// Command-line parameters passed to forked JVMs.
forkArgs: Listing<String>?

/// Published artifact name.
artifactName: NonSlashString?

/// POM metadata published with this module.
pomSettings: PomSettings?

/// Artifact version used when publishing this module.
publishVersion: NonSlashString?

/// Whether this module's tests may run in parallel in multiple JVM processes.
testParallelism: Boolean?

/// Whether test subprocesses should run in their sandbox working directory
/// instead of the project root.
testSandboxWorkingDir: Boolean?

/// Fully qualified `sbt.testing` framework implementation used to discover and
/// run tests.
testFramework:
  "mill.testng.TestNGFramework" |
  "com.novocode.junit.JUnitFramework" |
  "com.github.sbt.junit.jupiter.api.JupiterFramework" |
  "org.scalatest.tools.Framework" |
  "org.specs2.runner.Specs2Framework" |
  "utest.runner.Framework" |
  "munit.Framework" |
  "weaver.framework.CatsEffect" |
  "zio.test.sbt.ZTestFramework" |
  String?

/// Extra repositories used to resolve this module's dependencies.
repositories: Listing<String>?

// Postponed for the first PoC.
// experimentalPrecompiledModule: Boolean?

/// Nested child modules keyed by module name.
modules: Mapping<String, Module>?
