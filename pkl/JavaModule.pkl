/// Core schema for declarative Java modules.
///
/// This corresponds to Mill's `mill.javalib.JavaModule`.
open module JavaModule

extends "Module.pkl"

/// Options passed to the Java compiler.
///
/// When a custom JVM is configured, this may also include runtime flags for the
/// compiler JVM such as `-J-Xss8m`.
javacOptions: Listing<String>?

/// Error Prone dependencies for builds that use `ErrorProneModule`.
errorProneDeps: Listing<String>?

/// Additional Error Prone checks and configuration options.
errorProneOptions: Listing<String>?

/// Extra `javac` flags used to enable Error Prone integration.
errorProneJavacEnableOptions: Listing<String>?
