/// Core schema for Scala modules.
///
/// This corresponds to Mill's
/// [mill.scalalib.ScalaModule](https://mill-build.org/api/latest/mill/scalalib/ScalaModule.html).
open module mill.scalalib.ScalaModule

extends "../api/Module.pkl"

import "../scalalib/ScalaModule.pkl" as ThisModule

/// Scala version used to compile this module.
scalaVersion: String?

/// Command-line options passed to the Scala compiler.
scalacOptions: Listing<String>?

/// Scala compiler plugins resolved from Maven / Ivy repositories.
scalacPluginMvnDeps: Listing<String>?

/// Scala.js version for modules that target Scala.js.
scalaJSVersion: String?

/// Scala.js module kind, for example `NoModule`, `CommonJSModule`, or
/// `ESModule`.
moduleKind: ("NoModule" | "CommonJSModule" | "ESModule" | String)?

/// Scala Native version for modules that target Scala Native.
scalaNativeVersion: String?

/// Nested child modules keyed by module name.
///
/// If no module type is specified, defaults to [ScalaModule].
modules: Mapping<String, *module | Module>?

/// Scala test modules nested under a Scala module.
///
/// This corresponds to Mill's
/// [mill.scalalib.ScalaModule.ScalaTests](https://mill-build.org/api/latest/mill/scalalib/ScalaModule%24%24ScalaTests.html).
open class ScalaTests extends ThisModule
