/// Documentation package for the Mill Pkl schema.
///
/// The modules in this package define the Pkl schema for Mill.
amends "pkl:DocPackageInfo"

name = "mill"
version = "1.0.0"
importUri = "mill/"
authors { "self@odenix.org" }
issueTracker = "https://github.com/odenix/mill/issues"
sourceCode = "https://github.com/odenix/mill"
sourceCodeUrlScheme = "https://github.com/odenix/mill/blob/main/integration/feature/pkl-config/resources/schema/%{path}#L%{line}-L%{endLine}"
