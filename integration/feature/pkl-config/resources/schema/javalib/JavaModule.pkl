/// Core schema for Java modules.
///
/// This corresponds to Mill's
/// [mill.javalib.JavaModule](https://mill-build.org/api/latest/mill/javalib/JavaModule.html).
open module mill.javalib.JavaModule

extends "../api/Module.pkl"

import "../javalib/JavaModule.pkl" as ThisModule

/// Options passed to the Java compiler.
///
/// When a custom JVM is configured, this may also include runtime flags for the
/// compiler JVM such as `-J-Xss8m`.
javacOptions: Listing<String>?

/// Error Prone dependencies for builds that use `ErrorProneModule`.
errorProneDeps: Listing<String>?

/// Additional Error Prone checks and configuration options.
errorProneOptions: Listing<String>?

/// Extra `javac` flags used to enable Error Prone integration.
errorProneJavacEnableOptions: Listing<String>?

/// Nested child modules keyed by module name.
///
/// If no module type is specified, defaults to [JavaModule].
modules: Mapping<String, *module | Module>?

/// Java test modules nested under a Java module.
///
/// This corresponds to Mill's
/// [mill.javalib.JavaModule.JavaTests](https://mill-build.org/api/latest/mill/javalib/JavaModule%24%24JavaTests.html).
open class JavaTests extends ThisModule
