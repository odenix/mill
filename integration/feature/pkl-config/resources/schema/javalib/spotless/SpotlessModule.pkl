/// Spotless formatting support for Java, Scala, and Kotlin modules.
///
/// This mirrors Mill's
/// [mill.javalib.spotless.SpotlessModule](https://mill-build.org/api/latest/mill/javalib/spotless/SpotlessModule.html),
/// omitting non-configurable task methods and inherited members already
/// available on the surrounding module schema.
///
/// Nested types in this schema mirror the Spotless config model in
/// `mill.javalib.spotless.Format`.
module mill.javalib.spotless.SpotlessModule

extends "../../api/Trait.pkl"

/// A relative path reference resolved against the current module directory.
typealias RelPathRef = String

/// A string value provided inline or loaded from a file.
class ContentOrFile {
  /// Inline content to use directly.
  content: String?

  /// Relative path to a file containing the content.
  file: RelPathRef?
}

/// A lint suppression definition.
class Suppress {
  /// Relative path to the file to suppress.
  path: String?

  /// Formatter step name to suppress.
  step: String?

  /// Short lint code to suppress.
  shortCode: String?
}

/// Base type for Spotless formatter steps.
open class Step {}

/// Ensures files end with a trailing newline.
class EndWithNewline extends Step {}

/// Applies nested steps inside or outside matched fenced regions.
class Fence extends Step {
  /// Optional step name.
  name: String?

  /// Regex or marker pair used to find fenced regions.
  regex: Listing<String>?

  /// Whether matching regions should be preserved instead of formatted.
  preserve: Boolean?

  /// Nested formatter steps to apply.
  steps: Listing<Step>
}

/// Configures indentation using tabs or spaces.
class Indent extends Step {
  /// Indentation style, typically `TAB` or `SPACE`.
  type: ("TAB" | "SPACE" | String)?

  /// Number of spaces that correspond to one tab stop.
  numSpacesPerTab: Int?
}

/// Runs a JSR223 scripting engine as a formatter step.
class Jsr223 extends Step {
  /// Logical step name.
  name: String

  /// Maven / Ivy dependency containing the script engine.
  dependency: String

  /// Script engine name.
  engine: String

  /// Script source, either inline or from a file.
  script: ContentOrFile
}

/// Adds or updates a license header.
class LicenseHeader extends Step {
  /// Delimiter regex used to find the start of source content.
  delimiter: String

  /// Header content, inline or from a file.
  header: ContentOrFile?

  /// Optional step name.
  name: String?

  /// Optional pattern used to detect an existing header.
  contentPattern: String?

  /// Separator between start and end years.
  yearSeparator: String?

  /// Year handling mode.
  yearMode: ("PRESERVE" | "UPDATE_TO_TODAY" | "SET_FROM_GIT" | String)?

  /// Optional regex for initial lines to skip before inserting the header.
  skipLinesMatching: String?
}

/// Runs an external native executable as a formatter step.
class NativeCmd extends Step {
  /// Logical step name.
  name: String

  /// Executable path or command name.
  pathToExe: String

  /// Additional command-line arguments.
  arguments: Listing<String>?
}

/// Applies a regular-expression replacement.
class ReplaceRegex extends Step {
  /// Logical step name.
  name: String

  /// Regex to match.
  regex: String

  /// Replacement string.
  replacement: String
}

/// Applies a literal string replacement.
class Replace extends Step {
  /// Logical step name.
  name: String

  /// Target string to replace.
  target: String

  /// Replacement string.
  replacement: String
}

/// Removes trailing whitespace from each line.
class TrimTrailingWhitespace extends Step {}

/// Runs Cleanthat for Java sources.
class CleanthatJava extends Step {
  /// Optional formatter artifact override.
  groupArtifact: String?

  /// Optional formatter version override.
  version: String?

  /// Source JDK version to target.
  sourceJdkVersion: String?

  /// Enabled mutator groups.
  mutators: Listing<String>?

  /// Disabled mutators.
  excludedMutators: Listing<String>?

  /// Whether to enable draft mutators.
  includeDraft: Boolean?
}

/// Formats Java annotation layout.
class FormatAnnotations extends Step {
  /// Type annotations to add.
  addedTypeAnnotations: Listing<String>?

  /// Type annotations to remove.
  removedTypeAnnotations: Listing<String>?
}

/// Runs Google Java Format.
class GoogleJavaFormat extends Step {
  /// Optional formatter artifact override.
  groupArtifact: String?

  /// Optional formatter version override.
  version: String?

  /// Formatting style, typically `GOOGLE` or `AOSP`.
  style: ("GOOGLE" | "AOSP" | String)?

  /// Whether to reflow long string literals.
  reflowLongStrings: Boolean?

  /// Whether to reorder imports.
  reorderImports: Boolean?

  /// Whether to format Javadoc.
  formatJavadoc: Boolean?
}

/// Configures import ordering.
class ImportOrder extends Step {
  /// Explicit import-order groups.
  importOrder: Listing<String>?

  /// Whether wildcard imports should be ordered last.
  wildcardsLast: Boolean?

  /// Whether semantic sorting is enabled.
  semanticSort: Boolean?

  /// Package names to treat as packages.
  treatAsPackage: Listing<String>?

  /// Names to treat as classes.
  treatAsClass: Listing<String>?

  /// Whether Java import semantics should be used.
  forJava: Boolean?
}

/// Removes unused imports.
class RemoveUnusedImports extends Step {
  /// Optional formatter implementation to use.
  formatter: ("google-java-format" | "cleanthat-javaparser-unnecessaryimport" | String)?
}

/// Runs Diktat for Kotlin sources.
class Diktat extends Step {
  /// Optional Diktat version override.
  version: String?

  /// Whether the formatter should treat files as Kotlin scripts.
  isScript: Boolean?

  /// Relative path to the Diktat config file.
  configFile: RelPathRef?
}

/// Runs Ktfmt for Kotlin sources.
class Ktfmt extends Step {
  /// Optional Ktfmt version override.
  version: String?

  /// Formatting style preset.
  style: (
    "DEFAULT" |
    "META_FORMAT" |
    "DROPBOX_FORMAT" |
    "GOOGLE_FORMAT" |
    "KOTLINLANG_FORMAT" |
    String
  )?

  /// Maximum formatted line width.
  maxWidth: Int?

  /// Block indentation width.
  blockIndent: Int?

  /// Continuation indentation width.
  continuationIndent: Int?

  /// Whether unused imports should be removed.
  removeUnusedImports: Boolean?

  /// Whether trailing commas should be managed automatically.
  manageTrailingCommas: Boolean?
}

/// Runs KtLint for Kotlin sources.
class KtLint extends Step {
  /// Optional KtLint version override.
  version: String?

  /// Relative path to the `.editorconfig` file.
  configFile: RelPathRef?

  /// Additional custom ruleset dependencies.
  customRuleSets: Listing<String>?
}

/// Runs Scalafmt for Scala sources.
class ScalaFmt extends Step {
  /// Optional Scalafmt version override.
  version: String?

  /// Scala major version used to select the Scalafmt artifact.
  scalaMajorVersion: String?

  /// Relative path to the Scalafmt config file.
  configFile: RelPathRef?
}

/// A file-selection specification and the formatter steps to apply.
class Format {
  /// Formatter steps applied to matching files.
  steps: Listing<Step>

  /// Path matcher patterns for files to include.
  includes: Listing<String>

  /// Path matcher patterns for files to exclude.
  excludes: Listing<String>?

  /// Line-ending mode.
  lineEnding: String?

  /// Character encoding name.
  encoding: String?

  /// Lints to suppress.
  suppressions: Listing<Suppress>?
}

/// Explicit Spotless format definitions.
///
/// When unset, Mill first looks for `.spotless-formats.json` in the module
/// directory. If that file is absent, it falls back to built-in defaults for
/// Java, Kotlin, and Scala sources.
spotlessFormats: Listing<Format>?

/// Global path matcher patterns to exclude from formatting.
///
/// These patterns are evaluated relative to the module directory. For a root
/// module, Mill also excludes its standard `out` and BSP output folders by
/// default.
spotlessExcludes: Listing<String>?
